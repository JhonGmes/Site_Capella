# --- CONFIGURAÇÕES DO SERVER ---
PORT=3001
ALLOWED_ORIGINS=http://localhost:5173,https://seu-site-no-vercel.vercel.app

# --- SUPABASE ---
# Você pega esses links no painel do Supabase (Project Settings > API)
SUPABASE_URL=https://sua-url-aqui.supabase.co
SUPABASE_KEY=sua-chave-anon-public-ou-service-role

# --- SEGURANÇA ADMIN ---
ADMIN_USER=admin
ADMIN_SECRET=uma-chave-aleatoria-e-longa-aqui

# PARA A SENHA:
# Não coloque a senha em texto puro aqui.
# Rode o backend localmente e acesse:
# http://localhost:3001/api/utils/hash-password?pass=SUA_SENHA_AQUI
# Ele vai te dar um código começando com $2b$. Copie e cole abaixo:
ADMIN_PASS_HASH=cole_o_hash_aqui
